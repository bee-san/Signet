# Private-copy and validate this one route with configure-disabled-profile.py.
# The helper streams the one-time token into the dedicated profile's .env, never here.
mcp_servers:
  signet_disabled_approvals:
    url: "http://127.0.0.1:8789/mcp/approvals"
    headers:
      Authorization: "Bearer ${SIGNET_DISABLED_MCP_CALLER_TOKEN}"
    enabled: true
    connect_timeout: 10
    timeout: 120
    supports_parallel_tool_calls: false
    tools:
      resources: false
      prompts: false
    sampling:
      enabled: false
