# Review and merge this one server only into the intended disabled-staging profile.
# Store the one-time token output in that profile's mode-0600 .env, never here.
mcp_servers:
  signet_disabled_approvals:
    url: "http://127.0.0.1:8789/mcp/approvals"
    headers:
      Authorization: "Bearer ${SIGNET_DISABLED_MCP_CALLER_TOKEN}"
    enabled: true
    connect_timeout: 10
    timeout: 120
    supports_parallel_tool_calls: false
    tools:
      resources: false
      prompts: false
    sampling:
      enabled: false
